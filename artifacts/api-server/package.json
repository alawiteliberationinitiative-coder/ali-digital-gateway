    "pino-http": "^10.4.0",
    "tailwind-merge": "catalog:",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.17"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "catalog:",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.21.0",
    "typescript": "catalog:"
