<?xml version="1.0" encoding="utf-8"?>
<!--
  Data Extraction Rules (Android 12+) — يمنع استخراج بيانات التطبيق
  بما فيها JWT tokens المحفوظة في SharedPreferences / WebView storage.
  يُضاف في AndroidManifest.xml كـ android:dataExtractionRules="@xml/data_extraction_rules"
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="sharedpref" />
        <exclude domain="database" />
        <exclude domain="file" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="sharedpref" />
        <exclude domain="database" />
        <exclude domain="file" />
    </device-transfer>
</data-extraction-rules>
